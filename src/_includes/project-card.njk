<div class="project-card">
    <div class="project-image">
        <img src="{{ project.image }}" alt="{{ project.imageAlt }}">
    </div>
    <div class="project-content">
        <h3>{{ project.title }}</h3>
        <p>
            {{ description }}
        </p>
        <div class="project-tech">
            {% for tag in project.tech %}
            <span class="tech-tag">{{ tag }}</span>
            {% endfor %}
        </div>
        <div class="project-links">
            <a href="{{ project.detailUrl }}" class="btn btn-small">
                <i class="fas fa-expand"></i> View Details
            </a>
            <a href="{{ project.caseStudyUrl }}" class="btn btn-small btn-secondary" target="_blank">
                <i class="fas fa-external-link-alt"></i> Case Study
            </a>
        </div>
    </div>
</div>
