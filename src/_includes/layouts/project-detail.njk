<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Nishant Garg</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/NGLogo.png">
    <link rel="icon" type="image/png" sizes="64x64" href="/images/NGLogo.png">
    <link rel="shortcut icon" type="image/png" href="/images/NGLogo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/responsive.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="project-detail-page{% if pageClass %} {{ pageClass }}{% endif %}">
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <a href="/index.html">
                    <img src="/images/NGLogo.png" alt="Nishant Garg" title="Nishant Garg" class="nav-logo-img">
                </a>
            </div>
            <div class="nav-menu">
                <a href="/index.html" class="nav-link">Home</a>
                <a href="/blogs/" class="nav-link">Blogs</a>
                <a href="/projects/" class="nav-link active">Projects</a>
                <a href="/contact.html" class="nav-link">Contact</a>
            </div>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <main>
        <div class="project-detail-wrapper">
            <div class="back-button-container">
                <a href="/projects/" class="back-link">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
            <div class="project-detail-container">
                <div class="project-detail-header">
                    <h1>{{ heading or title }}</h1>
                </div>

                <div class="project-detail-content">
                    {{ content | safe }}
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Nishant Garg. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
