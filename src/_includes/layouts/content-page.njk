<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ seoTitle or title }} - Nishant Garg</title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="{{ metaDescription or site.description }}">
    <meta name="robots" content="{{ robots or site.robots }}">
    <meta name="language" content="{{ language or site.language }}">
    {% if canonicalUrl %}
    <link rel="canonical" href="{{ canonicalUrl }}">
    {% else %}
    <link rel="canonical" href="{{ site.siteUrl }}{{ page.url }}">
    {% endif %}
    
    <!-- Open Graph Tags -->
    <meta property="og:title" content="{{ seoTitle or title }}">
    <meta property="og:description" content="{{ metaDescription or site.description }}">
    {% set ogImg = ogImage or site.defaultOgImage %}
    {% if ogImg.startsWith('http') %}
    <meta property="og:image" content="{{ ogImg }}">
    {% else %}
    <meta property="og:image" content="{{ site.siteUrl }}{{ ogImg }}">
    {% endif %}
    <meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}">
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="{{ site.siteName }}">
    
    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ seoTitle or title }}">
    <meta name="twitter:description" content="{{ metaDescription or site.description }}">
    {% if ogImg.startsWith('http') %}
    <meta name="twitter:image" content="{{ ogImg }}">
    {% else %}
    <meta name="twitter:image" content="{{ site.siteUrl }}{{ ogImg }}">
    {% endif %}
    <meta name="twitter:creator" content="{{ site.twitterHandle }}">
    
    <!-- BlogPosting JSON-LD Schema -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": "{{ seoTitle or title }}",
        "description": "{{ metaDescription or site.description }}",
        "image": "{{ ogImage or site.defaultOgImage | replace('/', site.siteUrl + '/') }}",
        "datePublished": "{{ date | htmlDateString }}",
        {% if updated %}
        "dateModified": "{{ updated | htmlDateString }}",
        {% endif %}
        "author": {
            "@type": "Person",
            "name": "{{ site.author }}"
        },
        "publisher": {
            "@type": "Organization",
            "name": "{{ site.siteName }}",
            "url": "{{ site.siteUrl }}"
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "{{ site.siteUrl }}{{ page.url }}"
        }
    }
    </script>
    
    <link rel="icon" type="image/png" sizes="32x32" href="/images/NGLogo.png">
    <link rel="icon" type="image/png" sizes="64x64" href="/images/NGLogo.png">
    <link rel="shortcut icon" type="image/png" href="/images/NGLogo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/responsive.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <a href="/index.html">
                    <img src="/images/NGLogo.png" alt="Nishant Garg" title="Nishant Garg" class="nav-logo-img">
                </a>
            </div>
            <div class="nav-menu">
                <a href="/index.html" class="nav-link{% if activeNav == 'home' %} active{% endif %}">Home</a>
                <a href="/blogs/" class="nav-link{% if activeNav == 'blogs' %} active{% endif %}">Blogs</a>
                <a href="/projects/" class="nav-link{% if activeNav == 'projects' %} active{% endif %}">Projects</a>
                <a href="/contact.html" class="nav-link{% if activeNav == 'contact' %} active{% endif %}">Contact</a>
            </div>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <main>
        <section class="page-header">
            <div class="container">
                <h1>{{ title }}</h1>
                {% if excerpt %}
                <p>{{ excerpt }}</p>
                {% endif %}
            </div>
        </section>

        <section class="about-content">
            <div class="container">
                <article class="about-text">
                    {{ content | safe }}
                </article>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Nishant Garg. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
